<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:MuralDigital"
             xmlns:conv="clr-namespace:MuralDigital.Converters"
             x:Class="MuralDigital.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:InvertBoolConverter x:Key="InvertBool" />
            <conv:BoolToShortenTextConverter x:Key="BoolToShortenText" />
            <conv:IsNotEmptyConverter x:Key="IsNotEmpty" />
            <conv:WhatsAppFormattedTextConverter x:Key="WhatsAppFormat" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
