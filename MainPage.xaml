<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MuralDigital.ViewModels"
             x:Class="MuralDigital.MainPage"
             x:DataType="vm:MainViewModel"
             Title="MuralDigital">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Padding="12">

        <!-- HEADER -->
        <VerticalStackLayout Grid.Row="0" Spacing="8" Padding="0,0,0,12">
            <Label Text="🚨 MuralDigital" FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                <Label Text="Congregação:" VerticalOptions="Center" Grid.Row="0" />
                <Entry Text="{Binding Congregation}" Grid.Row="0" Grid.Column="1" />

                <Label Text="Título:" VerticalOptions="Center" Grid.Row="1" />
                <Entry Text="{Binding HeaderText}" Grid.Row="1" Grid.Column="1" />

                <Label Text="Visita (opcional):" VerticalOptions="Center" Grid.Row="2" />
                <Entry Text="{Binding VisitNote}" Placeholder="Ex: VISITA DO SUPERINTENDENTE 2-8 DE MARÇO / 2026"
                       Grid.Row="2" Grid.Column="1" />
            </Grid>
        </VerticalStackLayout>

        <!-- GROUPS -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" BindableLayout.ItemsSource="{Binding Groups}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:MuralGroupViewModel">
                        <Frame BorderColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark=#1E1E1E}"
                               CornerRadius="8" Padding="10"
                               HasShadow="True">
                            <VerticalStackLayout Spacing="6">
                                <!-- Group header -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                                    <Entry Text="{Binding Emoji}" WidthRequest="50" Grid.Column="0" />
                                    <Entry Text="{Binding Title}" FontAttributes="Bold" Grid.Column="1" />
                                    <Button Text="🗑️" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=RemoveGroupCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="Transparent" FontSize="16" Grid.Column="2"
                                            WidthRequest="40" HeightRequest="40" Padding="0" />
                                </Grid>

                                <Entry Text="{Binding Subtitle}" Placeholder="Subtítulo (opcional)" FontSize="12" />

                                <!-- Items -->
                                <VerticalStackLayout Spacing="4" BindableLayout.ItemsSource="{Binding Items}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MuralItemViewModel">
                                            <Frame BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
                                                   CornerRadius="6" Padding="8" BorderColor="Transparent">
                                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4" ColumnSpacing="4">
                                                    <Entry Text="{Binding Label}" Placeholder="Label (ex: Semana 1)"
                                                           FontAttributes="Bold" FontSize="13"
                                                           Grid.Row="0" Grid.ColumnSpan="2" />

                                                    <Entry Text="{Binding OriginalUrl}" Placeholder="Cole o link do Drive aqui..."
                                                           FontSize="12" Grid.Row="1" Grid.Column="0" />

                                                    <Button Text="{Binding IsShortening, Converter={StaticResource BoolToShortenText}}"
                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MuralGroupViewModel}}, Path=ShortenUrlCommand}"
                                                            CommandParameter="{Binding .}"
                                                            IsEnabled="{Binding IsShortening, Converter={StaticResource InvertBool}}"
                                                            FontSize="11" Padding="8,4"
                                                            Grid.Row="1" Grid.Column="1" />

                                                    <Label Grid.Row="2" Grid.ColumnSpan="2" FontSize="11"
                                                           TextColor="{AppThemeBinding Light=#1B8C1B, Dark=#66DD66}">
                                                        <Label.Text>
                                                            <MultiBinding StringFormat="{}✅ {0}">
                                                                <Binding Path="ShortUrl" />
                                                            </MultiBinding>
                                                        </Label.Text>
                                                        <Label.IsVisible>
                                                            <Binding Path="ShortUrl" Converter="{StaticResource IsNotEmpty}" />
                                                        </Label.IsVisible>
                                                    </Label>
                                                </Grid>
                                            </Frame>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                    <Button Text="+ Item" Command="{Binding AddItemCommand}"
                                            FontSize="12" Padding="10,4" />
                                    <Button Text="Encurtar Todos" Command="{Binding ShortenAllUrlsCommand}"
                                            FontSize="12" Padding="10,4" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- FOOTER -->
        <VerticalStackLayout Grid.Row="2" Spacing="6" Padding="0,8">
            <Label Text="Últimas Atualizações (rodapé):" FontSize="12" FontAttributes="Bold" />
            <Editor Text="{Binding FooterSection}" HeightRequest="80"
                    Placeholder="Texto livre do rodapé..." FontSize="12" />
        </VerticalStackLayout>

        <!-- STATUS BAR -->
        <Frame Grid.Row="3" CornerRadius="6" Padding="10,8"
               BackgroundColor="{Binding StatusColor}" BorderColor="Transparent"
               IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotEmpty}}">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="White" HeightRequest="18" WidthRequest="18" />
                <Label Text="{Binding StatusMessage}" FontSize="13" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Frame>

        <!-- ACTION BAR -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6" Padding="0,6">
            <Button Text="+ Grupo" Command="{Binding AddGroupCommand}" FontSize="11" Grid.Column="0" />
            <Button Text="🔗 Encurtar Tudo" Command="{Binding ShortenAllUrlsCommand}" FontSize="11" Grid.Column="1" />
            <Button Text="👁 Visualizar" Command="{Binding GenerateTextCommand}" FontSize="11" Grid.Column="2"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Tertiary}}"
                    TextColor="{StaticResource White}" />
            <Button Text="📋 Copiar" Command="{Binding CopyToClipboardCommand}" FontSize="11" Grid.Column="3" />
            <Button Text="💾 Salvar" Command="{Binding SaveDataCommand}" FontSize="11" Grid.Column="4" />
        </Grid>

    </Grid>

</ContentPage>
