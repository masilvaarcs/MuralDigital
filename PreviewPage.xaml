<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MuralDigital.ViewModels"
             x:Class="MuralDigital.PreviewPage"
             x:DataType="vm:PreviewViewModel"
             Title="Pré-visualização do Mural">

    <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,Auto" Padding="12" RowSpacing="8">

        <!-- STYLE SELECTOR -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
            <Label Text="Estilo:" VerticalOptions="Center" FontAttributes="Bold" FontSize="14" />

            <Picker Grid.Column="1"
                    ItemsSource="{Binding AvailableStyles}"
                    SelectedItem="{Binding SelectedStyle}"
                    ItemDisplayBinding="{Binding Name}"
                    FontSize="14" />

            <Label Grid.Column="2"
                   Text="{Binding SelectedStyle.Description}"
                   FontSize="11" TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                   VerticalOptions="Center" />
        </Grid>

        <!-- PREVIEW TEXT -->
        <Frame Grid.Row="1" CornerRadius="8" Padding="14"
               BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B2E1B}"
               BorderColor="{AppThemeBinding Light=#A5D6A7, Dark=#388E3C}">
            <ScrollView>
                <Label FormattedText="{Binding PreviewText, Converter={StaticResource WhatsAppFormat}}"
                       FontSize="13"
                       FontFamily="OpenSansRegular"
                       LineBreakMode="WordWrap" />
            </ScrollView>
        </Frame>

        <!-- CONTACTS SECTION -->
        <Frame Grid.Row="2" CornerRadius="8" Padding="10"
               BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}"
               BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
            <VerticalStackLayout Spacing="6">
                <Label Text="📱 Enviar para:" FontAttributes="Bold" FontSize="13" />

                <!-- Existing contacts with checkboxes -->
                <VerticalStackLayout Spacing="4" BindableLayout.ItemsSource="{Binding Contacts}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:ContactViewModel">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                                <CheckBox IsChecked="{Binding IsSelected}" Grid.Column="0"
                                          VerticalOptions="Center" />
                                <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold"
                                       VerticalOptions="Center" Grid.Column="1" />
                                <Label Text="{Binding DisplayPhone}" FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                       VerticalOptions="Center" Grid.Column="2" />
                                <Button Text="✕" FontSize="10" Padding="4,2"
                                        BackgroundColor="Transparent"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:PreviewViewModel}}, Path=RemoveContactCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding IsDefault, Converter={StaticResource InvertBool}}"
                                        Grid.Column="3"
                                        WidthRequest="30" HeightRequest="30" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Add new contact -->
                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="6">
                    <Entry Text="{Binding NewContactName}" Placeholder="Nome"
                           FontSize="12" Grid.Column="0" />
                    <Entry Text="{Binding NewContactPhone}" Placeholder="+55 51 9XXXX-XXXX"
                           FontSize="12" Keyboard="Telephone" Grid.Column="1" />
                    <Button Text="+ Adicionar" Command="{Binding AddContactCommand}"
                            FontSize="11" Padding="8,4" Grid.Column="2" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- STATUS BAR -->
        <Frame Grid.Row="3" CornerRadius="6" Padding="10,8"
               BackgroundColor="{Binding StatusColor}" BorderColor="Transparent"
               IsVisible="{Binding StatusMessage, Converter={StaticResource IsNotEmpty}}">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                   Color="White" HeightRequest="18" WidthRequest="18" />
                <Label Text="{Binding StatusMessage}" FontSize="13" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Frame>

        <!-- ACTION BUTTONS -->
        <Grid Grid.Row="4" ColumnDefinitions="*,*,2*" ColumnSpacing="10" Padding="0,4">
            <Button Text="← Voltar" Command="{Binding GoBackCommand}"
                    FontSize="13" Grid.Column="0" />

            <Button Text="📋 Copiar" Command="{Binding CopyOnlyCommand}"
                    FontSize="13" Grid.Column="1" />

            <Button Text="✅ Enviar via WhatsApp" Command="{Binding ConfirmStyleCommand}"
                    FontSize="13" Grid.Column="2"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource Tertiary}}"
                    TextColor="{StaticResource White}" />
        </Grid>

    </Grid>

</ContentPage>
